<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Moves History list view -->
    <record id="stock_move_line_cost_list_view" model="ir.ui.view">
        <field name="name">stock.move.line.cost.list</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="cost_at_move_date"
                       string="Running Cost"
                       optional="show"
                       readonly="1"
                       groups="hide_sale_stock_cost_margin.sale_cost_margin_hide_group"
                />
                <field name="move_type_label"
                       string="Move Type"
                       optional="show"
                       readonly="1"
                       widget="badge"
                       decoration-success="move_type_label == 'purchase'"
                       decoration-danger="move_type_label == 'sale'"
                       decoration-info="move_type_label == 'internal'"
                       decoration-muted="move_type_label == 'inventory'"
                       decoration-warning="move_type_label in ('scrap_merge', 'scrap_expired')"
                />
            </xpath>
        </field>
    </record>

    <!-- Detailed Operations tree inside the picking form -->
    <record id="stock_move_line_cost_detail_tree_view" model="ir.ui.view">
        <field name="name">stock.move.line.cost.detail.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="cost_at_move_date"
                       string="Running Cost"
                       optional="show"
                       readonly="1"
                       groups="hide_sale_stock_cost_margin.sale_cost_margin_hide_group"
                />
                <field name="move_type_label"
                       string="Move Type"
                       optional="show"
                       readonly="1"
                       widget="badge"
                       decoration-success="move_type_label == 'purchase'"
                       decoration-danger="move_type_label == 'sale'"
                       decoration-info="move_type_label == 'internal'"
                       decoration-muted="move_type_label == 'inventory'"
                       decoration-warning="move_type_label in ('scrap_merge', 'scrap_expired')"
                />
            </xpath>
        </field>
    </record>

</odoo>