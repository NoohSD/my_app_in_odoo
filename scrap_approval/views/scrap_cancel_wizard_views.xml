<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_scrap_cancel_wizard_form" model="ir.ui.view">
        <field name="name">scrap.cancel.wizard.form</field>
        <field name="model">scrap.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Rejection Reason">
                <group>
                    <field name="reason" placeholder="Please enter the reason for Rejection..."/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Confirm Rejection"
                            type="object"
                            class="btn-danger"/>
                    <button string="Discard"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>